# Foundit Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Clerk Authentication ───────────────────────────────────
# Get these from: https://clerk.com/dashboard → API Keys
# CLERK_ISSUER is the "Frontend API URL" shown in your Clerk dashboard
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# ⚠️  Remove in production — insecure, for local dev only:
# CLERK_JWT_INSECURE_NO_VERIFY=true

# ── HuggingFace (AI Embeddings) ───────────────────────────
# Get a free token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# ── Resend (Email Notifications) ──────────────────────────
# Get a free API key at: https://resend.com
# Optional — the platform works without it, just no email alerts
RESEND_API_KEY=re_...

# ── Server ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000

# ── Blockchain (Sepolia Testnet) ───────────────────────────
# These are the live deployed contracts — use as-is or deploy your own
# See blockchain/scripts/deploy.ts to deploy your own
REWARD_TOKEN_ADDRESS=0x660708adF644eb74DdF41BBcfC40a5Cc97B60fC9
HANDOVER_REGISTRY_ADDRESS=0x031f12624b3c9a1eb5c155FBB2e8e494168305c1
