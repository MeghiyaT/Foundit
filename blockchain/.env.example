# Foundit Blockchain — Environment Variables
# Copy this file to .env and fill in your values

# MetaMask deployer private key (NEVER commit your real .env)
# Get this from MetaMask → Account Details → Export Private Key
PRIVATE_KEY=your_metamask_private_key_here

# Sepolia RPC URL
# Get a free endpoint from Infura (https://infura.io) or Alchemy (https://alchemy.com)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_project_id

# Etherscan API key (optional — only needed for Etherscan badge verification)
# Get one free at https://etherscan.io/register
# Sourcify verification (npx hardhat verify) works without this
ETHERSCAN_API_KEY=
